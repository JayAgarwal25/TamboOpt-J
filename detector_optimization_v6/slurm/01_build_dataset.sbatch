#!/bin/bash
#SBATCH --job-name=tambo_01_build
#SBATCH --partition=gpu_requeue
#SBATCH --time=0-04:00:00
#SBATCH --gres=gpu:1
#SBATCH --mem=64G
#SBATCH --cpus-per-task=4
#SBATCH --requeue
#SBATCH --output=/n/home07/jagarwal/tambo_slurm_logs/%x_%j.out
#SBATCH --error=/n/home07/jagarwal/tambo_slurm_logs/%x_%j.err

# 64G covers the 35GB dual shower cache plus training pair tensors in RAM.
# gpu_requeue: GPU accelerates compute_labels_batch kernel (~50x vs CPU).
# PYTHONUNBUFFERED=1: progress prints appear immediately even if preempted.

set -euo pipefail

export PYTHONUNBUFFERED=1

echo "========================================"
echo "Job:     $SLURM_JOB_ID"
echo "Node:    $(hostname)"
echo "GPU:     $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null || echo 'unknown')"
echo "Start:   $(date)"
echo "========================================"

module load python
eval "$(mamba shell hook --shell bash)"
mamba config set changeps1 False
mamba activate /n/holylfs05/LABS/arguelles_delgado_lab/Everyone/jagarwal/envs/tambo

cd /n/holylfs05/LABS/arguelles_delgado_lab/Everyone/jagarwal/TambOpt-zlt/detector_optimization_v6

python 01_build_dataset_northeast.py

echo "========================================"
echo "Done:    $(date)"
echo "========================================"
